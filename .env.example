# API Keys and Configuration
# Get your API keys from:
# - api-sports.io: https://dashboard.api-sports.io/register
# - football-data.org: https://www.football-data.org/

API_KEY_SPORTS=your_api_key_here
API_KEY_FOOTBALL_DATA=your_api_key_here

# Logging
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_ENABLED=True
SCHEDULE_TIME_1=00:00
SCHEDULE_TIME_2=12:00

# Initial bankroll for backtesting
INITIAL_BANKROLL=1000

# Kelly Criterion fraction for bet sizing
KELLY_FRACTION=0.25

# Minimum probability threshold for placing bets
MIN_PROBABILITY=0.55